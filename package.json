{
  "name": "bioclaw",
  "version": "0.1.0",
  "description": "AI-powered biology research assistant. Run BLAST, sequence analysis, and molecular tools from WhatsApp. Built on Claude Agent SDK.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "web": "node scripts/start-web.mjs",
    "open:web": "node scripts/open-local-web.mjs",
    "stop:web": "node scripts/stop-bioclaw-web.mjs",
    "cli": "tsx src/cli.ts",
    "auth": "tsx src/channels/whatsapp/auth.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@slack/bolt": "^4.6.0",
    "@wecom/aibot-node-sdk": "^1.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "marked": "^17.0.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "weixin-agent-sdk": "^0.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
